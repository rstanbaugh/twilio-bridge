# Example .env for Twilio Bridge (do not commit to version control)

# Twilio credentials
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_PHONE_NUMBER=+15555555555

# Bridge configuration
TWILIO_BRIDGE_HOST=127.0.0.1
TWILIO_BRIDGE_PORT=3001
TWILIO_BRIDGE_LOG_LEVEL=INFO
TWILIO_SMS_FALLBACK_MESSAGE=Odin is temporarily unavailable.
TWILIO_VALIDATE_SIGNATURE=true

# OpenClaw Gateway
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=your_openclaw_gateway_token_here
OPENCLAW_TIMEOUT_SECONDS=10
